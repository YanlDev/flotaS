# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Variables de entorno (NUNCA subir) ──────────────────────────
.env
.env.local
.env.production
.env.test
# .env.example sí se sube (tiene estructura sin valores reales)

# ─── Prisma: cliente generado (se regenera con prisma generate) ──
/src/generated/

# ─── Testing & E2E ───────────────────────────────────────────────
/coverage
/e2e
/test-results/
/playwright-report/

# ─── Scripts de debug y seeds de prueba (no van a producción) ────
/scripts/debug-test.js
/scripts/seed-test-users.sql
/scripts/cleanup-test-data.sql

# ─── Logs ────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Misc ────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ─── Vercel ──────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
